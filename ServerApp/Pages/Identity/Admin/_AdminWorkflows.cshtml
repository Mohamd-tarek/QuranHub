@model (string workflow, string theme)

@{ 
    Func<string, string> getClass = (string feature) => 
        feature != null && feature.Equals(Model.workflow) ? "active" : "";
}

<a class="btn btn-@Model.theme w-100 m-2 @getClass("Dashboard")" 
        asp-page="Dashboard">
    Dashboard
</a>
<a class="btn btn-@Model.theme w-100 m-2 @getClass("Features")" 
        asp-page="Features">
    Store Features
</a>

<a class="btn btn-@Model.theme w-100 m-2 @getClass("List")" 
        asp-page="View">
    List Users
</a>
<a class="btn btn-@Model.theme w-100 m-2 @getClass("Edit")" 
        asp-page="Edit">
    Edit Users
</a>